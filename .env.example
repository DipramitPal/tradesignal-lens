# =============================================================
# TradeSignal Lens - Environment Configuration
# =============================================================
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
# =============================================================

# --- Alpha Vantage (primary data source) ---
# Free key from alphavantage.co (25 requests/day on free tier)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
DEFAULT_OUTPUT_SIZE=compact

# --- Stock Watchlist ---
# Comma-separated BSE symbols (append .BSE) or NSE symbols
# Leave empty to use the default blue-chip watchlist
STOCK_SYMBOLS=RELIANCE.BSE,TCS.BSE,INFY.BSE,HDFCBANK.BSE,BEL.BSE,CUMMINSIND.BSE

# --- News API (optional, free tier at newsapi.org) ---
NEWS_API_KEY=your_newsapi_key_here

# --- Reddit API (optional, create app at reddit.com/prefs/apps) ---
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=tradesignal-lens/1.0
REDDIT_SUBREDDITS=IndianStockMarket,IndianStreetBets,DalalStreetTalks,IndiaInvestments

# --- LLM Provider ---
# Provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514

# Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API key (alternative, get from platform.openai.com)
OPENAI_API_KEY=your_openai_api_key_here

# --- Risk & Signal Weights ---
# Weight given to sentiment vs technical analysis (must sum to 1.0)
SENTIMENT_WEIGHT=0.3
TECHNICAL_WEIGHT=0.7
MAX_RSI_BUY=35
MIN_RSI_SELL=65
